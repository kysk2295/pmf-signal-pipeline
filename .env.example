# Reddit API (https://www.reddit.com/prefs/apps → "create another app" → script 선택)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=pmf-signal-bot/1.0

# Anthropic API (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_key

# Notion API (https://www.notion.so/my-integrations → New integration)
NOTION_TOKEN=your_notion_token
NOTION_DATABASE_ID=your_database_id
